# Public site URL (no trailing slash) — used for sitemap, canonical, and Open Graph tags at build time
# After first Cloudflare deploy, set this to https://<your-project>.pages.dev and redeploy
VITE_SITE_URL=https://sriramkancherla.pages.dev

# Web3Forms access key for the contact form
VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here
